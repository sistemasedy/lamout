<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_move_form_lamout_purchases" model="ir.ui.view">
        <field name="name">account.move.form.lamout.purchases</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet/group" position="inside">
                <group string="Datos fiscales de compra"
                       invisible="move_type not in ('in_invoice', 'in_refund')">
                    <field name="lamout_proveedor_rnc"/>
                    <field name="lamout_ncf"/>
                    <field name="lamout_tipo_comprobante"/>
                    <field name="lamout_categoria_material"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
