<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_project_project_form_lamout" model="ir.ui.view">
        <field name="name">project.project.form.lamout</field>
        <field name="model">project.project</field>
        <field name="inherit_id" ref="project.edit_project"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet//group" position="inside">
                <group string="Lamout">
                    <field name="lamout_code"/>
                    <field name="account_id" string="Cuenta Analítica"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
