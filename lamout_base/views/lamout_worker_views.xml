<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_lamout_worker_list" model="ir.ui.view">
        <field name="name">lamout.worker.list</field><field name="model">lamout.worker</field>
        <field name="arch" type="xml"><list><field name="name"/><field name="cargo"/><field name="jornal"/><field name="comida_sugerida"/></list></field>
    </record>
    <record id="view_lamout_worker_form" model="ir.ui.view">
        <field name="name">lamout.worker.form</field><field name="model">lamout.worker</field>
        <field name="arch" type="xml"><form><sheet><group><field name="active" widget="boolean_toggle"/><field name="name"/><field name="cargo"/><field name="currency_id"/><field name="jornal"/><field name="comida_sugerida"/><field name="notes"/></group></sheet></form></field>
    </record>
    <record id="view_lamout_worker_search" model="ir.ui.view">
        <field name="name">lamout.worker.search</field><field name="model">lamout.worker</field>
        <field name="arch" type="xml"><search><field name="name"/><field name="cargo"/><filter name="archived" string="Archivados" domain="[('active','=',False)]"/></search></field>
    </record>
    <record id="action_lamout_worker" model="ir.actions.act_window">
        <field name="name">Obreros</field><field name="res_model">lamout.worker</field><field name="view_mode">list,form</field>
    </record>
</odoo>
